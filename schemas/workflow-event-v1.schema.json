    "workflow_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "schema_version": {
      "const": "1.0"
    }
  }
